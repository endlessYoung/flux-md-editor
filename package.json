{
  "name": "flux-md-editor",
  "version": "0.1.0",
  "description": "A local-first, pure front-end Markdown editor with preview, code highlight, KaTeX and Mermaid.",
  "type": "module",
  "main": "dist/flux-md-editor.umd.js",
  "module": "dist/flux-md-editor.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flux-md-editor.es.js",
      "require": "./dist/flux-md-editor.umd.js"
    }
  },
  "sideEffects": [
    "src/style/editor.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.37",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-toc-done-right": "^4.2.0",
    "mermaid": "^11.12.3",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2"
  }
}
